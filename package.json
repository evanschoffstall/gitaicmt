{
  "name": "gitaicmt",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/cli/command-line-interface.js",
  "bin": {
    "gitaicmt": "dist/cli/command-line-interface.js"
  },
  "scripts": {
