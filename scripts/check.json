{
  "thresholds": {
    "lineCoverageThreshold": 85,
    "typeCoverageThreshold": 98,
    "testTimeoutMs": 5000,
    "testCommandTimeoutMs": 120000,
    "testCommandTimeoutEnvVar": "CHECK_TEST_COMMAND_TIMEOUT_MS"
  },
  "paths": {
    "junitPath": "coverage/test-results.xml",
    "lcovPath": "coverage/lcov.info"
  },
  "coverageExcludedFiles": [],
  "steps": [
    {
      "key": "format",
      "enabled": true,
      "label": "format",
      "preRun": true,
      "cmd": "bunx",
      "args": ["prettier", "--write", "."]
    },
    {
      "key": "junit",
      "enabled": true,
      "label": "junit",
      "handler": "test",
      "cmd": "bun",
      "args": [
        "test",
        "--timeout={testTimeoutMs}",
        "--coverage",
        "--coverage-reporter=lcov",
        "--coverage-dir=coverage",
        "--reporter=junit",
        "--reporter-outfile={junitPath}"
      ],
      "passMsg": "",
      "failMsg": "",
      "summary": {
        "type": "test-runner"
      }
    },
    {
      "key": "types",
      "enabled": true,
      "label": "tsc",
      "cmd": "tsc",
      "args": ["--noEmit"],
      "passMsg": "typecheck clean",
      "failMsg": "typecheck failed",
      "summary": { "type": "simple" }
    },
    {
      "key": "lint",
      "enabled": true,
      "label": "eslint",
      "handler": "lint",
      "passMsg": "lint clean",
      "failMsg": "lint failed",
      "summary": {
        "type": "pattern",
        "patterns": [
          {
            "regex": "[✖xX]\\s+(\\d+)\\s+problems?\\s*\\((\\d+)\\s+errors?,\\s*(\\d+)\\s+warnings?\\)",
            "type": "match",
            "format": "{1} problems ({2} errors, {3} warnings)"
          }
        ],
        "default": "lint clean"
      },
      "config": {
        "globExtensions": ["js", "mjs", "cjs", "ts", "jsx", "tsx"],
        "skipDirs": [
          "node_modules",
          ".next",
          "dist",
          "build",
          "coverage",
          ".cache"
        ],
        "maxFiles": 5000,
        "args": [
          "eslint",
          ".",
          "--cache",
          "--cache-strategy",
          "content",
          "--cache-location",
          ".cache/eslint",
          "--fix",
          "--concurrency"
        ]
      }
    },
    {
      "key": "jscpd",
      "enabled": true,
      "label": "jscpd",
      "cmd": "bunx",
      "args": ["jscpd", "--config", ".jscpd.json"],
      "passMsg": "no duplicate stats detected",
      "failMsg": "duplicates found",
      "summary": {
        "type": "pattern",
        "patterns": [
          {
            "regex": "│ Total:",
            "type": "table-row",
            "cellSep": "│",
            "format": "{4} clones · {5} lines · {6} tokens · {1} files"
          },
          {
            "regex": "Found\\s+(\\d+)\\s+clones?",
            "type": "match",
            "format": "{1} clones"
          }
        ],
        "default": "no duplicate stats detected"
      }
    },
    {
      "key": "knip",
      "enabled": true,
      "label": "knip",
      "cmd": "bunx",
      "args": ["knip", "--config", "knip.json", "--cache"],
      "passMsg": "unused dependency check clean",
      "failMsg": "knip failed",
      "summary": { "type": "simple" }
    },
    {
      "key": "madge",
      "enabled": true,
      "label": "madge",
      "cmd": "bunx",
      "args": ["madge@8", "--circular", "--extensions", "ts,tsx", "src"],
      "passMsg": "0 circular dependencies",
      "failMsg": "circular dependencies found",
      "outputFilter": {
        "type": "stripLines",
        "pattern": "\\b\\d+\\s+warnings?\\b"
      },
      "summary": {
        "type": "pattern",
        "patterns": [
          {
            "regex": "No circular dependency found",
            "type": "literal",
            "format": "0 circular dependencies"
          },
          {
            "regex": "Found\\s+(\\d+)\\s+circular\\s+dependenc",
            "type": "match",
            "format": "{1} circular dependencies"
          }
        ],
        "default": "circular dependency check completed"
      }
    },
    {
      "key": "dependency-cruiser",
      "enabled": true,
      "label": "dependency-cruiser",
      "cmd": "bunx",
      "args": ["depcruise", "--no-config", "src", "--output-type", "err"],
      "passMsg": "no dependency violations",
      "failMsg": "dependency-cruiser failed",
      "summary": {
        "type": "pattern",
        "patterns": [
          {
            "regex": "no dependency violations found \\((\\d+) modules, (\\d+) dependencies cruised\\)",
            "type": "match",
            "format": "0 dependency violations · {1} modules · {2} dependencies"
          }
        ],
        "default": "dependency cruise completed"
      }
    },
    {
      "key": "type-coverage",
      "enabled": true,
      "label": "type-coverage",
      "cmd": "bunx",
      "args": [
        "type-coverage",
        "--at-least",
        "{typeCoverageThreshold}",
        "--cache",
        "--cache-directory",
        ".cache/type-coverage"
      ],
      "passMsg": "type coverage completed",
      "failMsg": "type coverage below threshold",
      "summary": {
        "type": "pattern",
        "patterns": [
          {
            "regex": "\\((\\d+)\\s*\\/\\s*(\\d+)\\)\\s*([\\d.]+)%",
            "type": "match",
            "format": "{3}% ({1}/{2}) · threshold {typeCoverageThreshold}%"
          }
        ],
        "default": "type coverage completed"
      }
    },
    {
      "key": "stylelint",
      "enabled": true,
      "label": "stylelint",
      "cmd": "bunx",
      "args": [
        "stylelint",
        "src/**/*.{css,scss}",
        "--allow-empty-input",
        "--cache",
        "--cache-location",
        ".cache/stylelint",
        "--cache-strategy",
        "content"
      ],
      "passMsg": "stylelint clean",
      "failMsg": "stylelint failed",
      "summary": { "type": "simple" }
    },
    {
      "key": "purgecss",
      "enabled": true,
      "label": "purgecss",
      "handler": "inline-ts",
      "passMsg": "no unused CSS selectors",
      "failMsg": "unused CSS selectors found",
      "summary": { "type": "simple" },
      "config": {
        "source": "async ({ data, cwd, join, importModule, ok, fail }) => {\n  const { cssFiles, contentGlobs, safelists, selectorPrefix } = data;\n  if (!Array.isArray(cssFiles) || !Array.isArray(contentGlobs) || !Array.isArray(safelists) || typeof selectorPrefix !== \"string\") {\n    return fail(\"purgecss config is invalid\\n\");\n  }\n  const safelistRe = safelists.map((pattern: string) => new RegExp(pattern));\n  const safePattern = safelists.length > 0 ? new RegExp(safelists.join(\"|\")) : null;\n  const purgeCssModule = await importModule(\"purgecss\") as {\n    PurgeCSS: new () => {\n      purge: (options: {\n        css: string[];\n        content: string[];\n        rejected: boolean;\n        safelist: { greedy: RegExp[] };\n      }) => Promise<Array<{ rejected?: string[] }>>;\n    };\n  };\n  const [result] = await new purgeCssModule.PurgeCSS().purge({\n    css: cssFiles.map((file: string) => join(cwd, file)),\n    content: contentGlobs.map((glob: string) => join(cwd, glob)),\n    rejected: true,\n    safelist: { greedy: safelistRe }\n  });\n  const rejected = Array.isArray(result?.rejected) ? result.rejected : [];\n  const unused = rejected.filter((selector: string) => selector.startsWith(selectorPrefix) && !(safePattern?.test(selector) ?? false));\n  if (unused.length === 0) return ok(\"no unused CSS selectors found\\n\");\n  return fail(unused.map((selector: string) => \"  unused: \" + selector).join(\"\\n\") + \"\\nfound \" + unused.length + \" unused CSS selector(s)\\n\");\n}",
        "data": {
          "cssFiles": ["src/app/globals.css"],
          "contentGlobs": [
            "src/**/*.{tsx,ts,jsx,js}",
            "src/components/components.css"
          ],
          "safelists": ["^dark$", "^motion-profile-"],
          "selectorPrefix": "."
        }
      }
    },
    {
      "key": "tsd",
      "enabled": true,
      "label": "tsd",
      "cmd": "bunx",
      "args": [
        "tsd",
        "--typings",
        "next-env.d.ts",
        "--files",
        "next-env.test-d.ts"
      ],
      "passMsg": "type definition tests clean",
      "failMsg": "tsd failed",
      "summary": { "type": "simple" }
    },
    {
      "key": "secretlint",
      "enabled": true,
      "label": "secretlint",
      "cmd": "bunx",
      "args": ["secretlint", "**/*", "--secretlintignore", ".secretlintignore"],
      "passMsg": "no secret findings",
      "failMsg": "secretlint failed",
      "summary": { "type": "simple" }
    },
    {
      "key": "prettier",
      "enabled": true,
      "label": "prettier",
      "cmd": "bunx",
      "args": [
        "prettier",
        "--check",
        ".",
        "--cache",
        "--cache-location",
        ".cache/prettier"
      ],
      "passMsg": "formatting compliant",
      "failMsg": "prettier failed",
      "summary": { "type": "simple" }
    },
    {
      "key": "semgrep",
      "enabled": true,
      "label": "semgrep",
      "cmd": "semgrep",
      "args": [
        "scan",
        "--config",
        "p/default",
        "--error",
        "--metrics",
        "off",
        "--exclude=tests",
        "--exclude=src/components/ui",
        "--exclude-rule=javascript.lang.security.audit.react-dangerouslysetinnerhtml.react-dangerouslysetinnerhtml",
        "--exclude-rule=typescript.react.security.audit.react-dangerouslysetinnerhtml.react-dangerouslysetinnerhtml",
        "--exclude-rule=problem-based-packs.insecure-transport.js-node.bypass-tls-verification.bypass-tls-verification",
        "--quiet",
        "src"
      ],
      "passMsg": "rule scan clean",
      "failMsg": "semgrep failed",
      "summary": { "type": "simple" }
    },
    {
      "key": "@0xts/gitleaks-cli",
      "enabled": true,
      "label": "@0xts/gitleaks-cli",
      "cmd": "bunx",
      "args": [
        "@0xts/gitleaks-cli",
        "detect",
        "-s",
        "src",
        "--no-git",
        "-c",
        ".gitleaks.toml"
      ],
      "passMsg": "secret scan clean",
      "failMsg": "gitleaks failed",
      "summary": { "type": "simple" }
    }
  ]
}
